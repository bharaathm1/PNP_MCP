# .env.example - Environment Variables Template
# Copy this file to .env and update with your values

# Server Configuration
SERVER_NAME="MCP Server Basic"
SERVER_HOST="localhost"  # Use 'hostname --long' to get your full hostname (e.g., plxcag2160.pdx.intel.com)
SERVER_PORT="11200"

# Environment
ENVIRONMENT="development"  # development, staging, production

# Security
MASK_ERROR_DETAILS="false"  # Set to "true" in production to hide sensitive error details
SECRET_KEY=""  # Generate using: python generate_secret_key.py - Keep consistent for stable tokens across restarts

# MCP Configuration
ON_DUPLICATE_TOOLS="warn"      # warn, error, replace, ignore
ON_DUPLICATE_PROMPTS="warn"
ON_DUPLICATE_RESOURCES="warn"

# Performance
MAX_TOOL_EXECUTION_TIME="300"  # seconds
MAX_RESOURCE_SIZE="10485760"   # bytes (10MB)

# SSE Settings
SSE_HEARTBEAT_INTERVAL="30"    # seconds
SSE_MAX_CONNECTIONS="100"
